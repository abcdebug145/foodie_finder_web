# Foodie Finder Frontend Environment Variables Template
# Copy this file to '.env' or '.env.production' and configure as needed.

# 1. Base URL for the Backend API (e.g. https://api.foodiefinder.com)
# If left blank, API calls will default to relative URLs (e.g. /api/v1/...) 
# which works if frontend and backend are hosted on the same domain or proxied.
VITE_API_URL=

# 2. Base URL for WebSockets (e.g. wss://api.foodiefinder.com/api/v1/notifications/ws)
# If left blank, it is automatically derived from VITE_API_URL.
VITE_WS_URL=
